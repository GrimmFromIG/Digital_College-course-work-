@page "/student/my-grades"
@inject ApiClient ApiClient
@inject AuthService AuthService
@inject ISnackbar Snackbar

<PageTitle>Мої оцінки</PageTitle>

@if (!AuthService.IsInRole("Student"))
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Elevation="3" Class="my-4">
        <MudText Typo="Typo.h6">Ця сторінка доступна лише для Студентів</MudText>
        <MudText>Будь ласка, авторизуйтесь як студент, щоб переглянути свої результати.</MudText>
    </MudAlert>
}
else
{
    <MudGrid Class="mt-2">
        <MudItem xs="12" md="4">
            <MudCard Elevation="3" Class="pa-4 text-center rounded-lg mud-theme-dark">
                <MudCardContent>
                    <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Style="width: 80px; height: 80px; font-size: 2.5rem;" Class="mx-auto mb-4">
                        @if (AuthService.CurrentUser?.FullName != null && AuthService.CurrentUser.FullName.Any())
                        {
                            @(AuthService.CurrentUser.FullName.FirstOrDefault().ToString().ToUpper())
                        }
                        else
                        {

                            @("?")
                        }
                    </MudAvatar>

                    <MudText Typo="Typo.h5" Class="font-weight-bold mb-1">
                        @(AuthService.CurrentUser?.FullName ?? "Завантаження...")
                    </MudText>

                    <MudDivider Class="my-6" Light="true" />

                    <MudPaper Elevation="0" Class="pa-4 text-start rounded-lg" Style="background-color: rgba(255,255,255,1);">
                        <div class="d-flex justify-space-between align-center">
                            <MudText Typo="Typo.caption" Class="text-uppercase font-weight-bold text-muted">Середній бал (GPA):</MudText>
                            <MudText Typo="Typo.h4" Color="Color.Warning" Class="font-weight-bold m-0">@CalculateGpa().ToString("F1")</MudText>
                        </div>

                        <MudProgressLinear Color="@GetGradeColor(CalculateGpa())" Value="@CalculateGpa()" Class="my-3" Size="Size.Medium" Rounded="true" />

                        <MudText Typo="Typo.caption">
                            @if (grades == null || !grades.Any())
                            {
                                <span class="text-muted">Оцінки ще не завантажено.</span>
                            }
                            else if (CalculateGpa() >= 74)
                            {

                                <span style="color: var(--mud-palette-success);">🎉 Відмінний результат! Так тримати.</span>
                            }
                            else if (CalculateGpa() >= 60)
                            {

                                <span style="color: var(--mud-palette-warning);">👍 Гарний рівень, піднатисніть на сесії.</span>
                            }
                            else
                            {

                                <span style="color: var(--mud-palette-error);">⚠️ Увага! Потрібно покращити результати.</span>
                            }
                        </MudText>
                    </MudPaper>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" md="8">
            <MudCard Elevation="3" Class="h-100 rounded-lg">
                <MudCardHeader Class="pb-0">
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Class="font-weight-bold d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.MenuBook" Color="Color.Primary" Class="mr-2" />
                            Електронний заліковий лист
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudTable Items="@grades" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@(grades == null)" LoadingProgressColor="Color.Info" Elevation="0">
                        <HeaderContent>
                            <MudTh Style="width: 25%;">Дата</MudTh>
                            <MudTh>Дисципліна</MudTh>
                            <MudTh Style="width: 20%; text-align: center;">Оцінка</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Дата"><MudText Typo="Typo.body2" Class="text-muted">@context.DateAssigned.ToString("dd.MM.yyyy")</MudText></MudTd>
                            <MudTd DataLabel="Дисципліна"><MudText Typo="Typo.body1" Class="font-weight-bold">@context.DisciplineName</MudText></MudTd>
                            <MudTd DataLabel="Оцінка" Style="text-align: center;">
                                <MudChip T="string" Color="@GetGradeColor(context.Value)" Variant="Variant.Filled" Size="Size.Medium">@context.Value</MudChip>
                            </MudTd>
                        </RowTemplate>
                        <NoRecordsContent>
                            <MudText Typo="Typo.body1" Align="Align.Center" Class="py-4 text-muted">У вашій заліковій книжці ще немає виставлених оцінок.</MudText>
                        </NoRecordsContent>
                    </MudTable>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@code {
    private List<GradeModel> grades;

    protected override async Task OnInitializedAsync()
    {
        if (AuthService.IsInRole("Student")) await LoadGrades();
    }

    private async Task LoadGrades()
    {
        if (AuthService.CurrentUser == null) return;
        try { grades = await ApiClient.GetStudentGradesAsync(AuthService.CurrentUser.Id); }
        catch (Exception ex) { grades = new List<GradeModel>(); Snackbar.Add("Не вдалося завантажити оцінки.", Severity.Error); }
    }

    private double CalculateGpa() { if (grades == null || !grades.Any()) return 0; return grades.Average(g => g.Value); }
    private Color GetGradeColor(double value) { if (value >= 74) return Color.Success; if (value >= 60) return Color.Warning; return Color.Error; }
}
