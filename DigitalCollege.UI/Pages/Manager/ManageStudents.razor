@page "/manager/students"
@inject ApiClient ApiClient
@inject ISnackbar Snackbar

<MudText Typo="Typo.h4" Class="mb-4">Керування студентами</MudText>

<MudCard Elevation="3" Class="mb-4">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">@(isEditMode ? "Редагувати студента" : "Додати студента")</MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        <MudGrid AlignItems="AlignItems.Center">
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="currentStudent.FullName"
                              Label="ПІБ студента"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>

            <MudItem xs="12" md="3">
                <MudSelect T="int" @bind-Value="currentStudent.GroupId" Label="Оберіть групу" Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem T="int" Value="0">-- Оберіть групу --</MudSelectItem>
                    @if (groupsList != null)
                    {
                        @foreach (var g in groupsList)
                        {
                            <MudSelectItem T="int" Value="@g.Id">@g.Name</MudSelectItem>
                        }
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="3" Class="d-flex gap-2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveStudent" Class="flex-grow-1">
                    Зберегти
                </MudButton>
                @if (isEditMode)
                {
                    <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="CancelEdit">
                        Скасувати
                    </MudButton>
                }
            </MudItem>
        </MudGrid>
    </MudCardContent>
</MudCard>

<div class="d-flex flex-column flex-md-row gap-3 mb-4">
    <MudTextField @bind-Value="SearchTerm"
                  @bind-Value:after="LoadStudents"
                  Immediate="true"
                  Placeholder="Пошук за ПІБ..."
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Class="flex-grow-1" />

    <MudNumericField T="int?" @bind-Value="FilterGroupId"
                     @bind-Value:after="LoadStudents"
                     Placeholder="ID Групи..."
                     Adornment="Adornment.Start"
                     AdornmentIcon="@Icons.Material.Filled.FilterList"
                     Variant="Variant.Outlined"
                     Margin="Margin.Dense"
                     Style="min-width: 150px;"
                     Clearable="true" />

    <MudSelect T="string" @bind-Value="SortBy"
               @bind-Value:after="LoadStudents"
               Variant="Variant.Outlined"
               Margin="Margin.Dense"
               Style="min-width: 150px;">
        <MudSelectItem Value="@("")">А - Я</MudSelectItem>
        <MudSelectItem Value="@("name_desc")">Я - А</MudSelectItem>
    </MudSelect>
</div>

<MudTable Items="@students" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@(students == null)" LoadingProgressColor="Color.Info" Elevation="3">
    <HeaderContent>
        <MudTh>ID</MudTh>
        <MudTh>ПІБ</MudTh>
        <MudTh>ID Групи</MudTh>
        <MudTh>Дії</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="ID">@context.Id</MudTd>
        <MudTd DataLabel="ПІБ">@context.FullName</MudTd>
        <MudTd DataLabel="Група">
            <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Text">
                @context.GroupName
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Дії">
            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Warning" OnClick="() => EditStudent(context)" Class="mr-2">
                Змінити
            </MudButton>
            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Error" OnClick="() => DeleteStudent(context.Id)">
                Видалити
            </MudButton>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Typo="Typo.body1" Align="Align.Center" Class="py-4 text-muted">Студентів не знайдено.</MudText>
    </NoRecordsContent>
</MudTable>

@code {
    private List<StudentModel> students;
    private StudentModel currentStudent = new();
    private bool isEditMode = false;
    private string SearchTerm = "";
    private int? FilterGroupId;
    private string SortBy = "";

    // 1. ДОДАНО ЗМІННУ ДЛЯ ГРУП
    private List<GroupModel> groupsList;

    protected override async Task OnInitializedAsync()
    {
        await LoadStudents();
        await LoadGroups(); // 2. ЗАВАНТАЖУЄМО ГРУПИ ПРИ ВІДКРИТТІ СТОРІНКИ
    }

    private async Task LoadStudents()
    {
        try
        {
            students = await ApiClient.GetStudentsAsync(SearchTerm, FilterGroupId, SortBy);
        }
        catch (Exception ex)
        {
            Snackbar.Add("Помилка завантаження списку студентів.", Severity.Error);
            Console.WriteLine(ex.Message);
        }
    }

    // 3. ДОДАНО МЕТОД ДЛЯ ЗАВАНТАЖЕННЯ ГРУП
    private async Task LoadGroups()
    {
        try
        {
            groupsList = await ApiClient.GetGroupsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Не вдалося завантажити список груп.", Severity.Error);
            Console.WriteLine(ex.Message);
        }
    }

    private async Task SaveStudent()
    {
        if (string.IsNullOrWhiteSpace(currentStudent.FullName) || currentStudent.GroupId == 0)
        {
            Snackbar.Add("Будь ласка, введіть ПІБ та оберіть групу.", Severity.Warning);
            return;
        }

        try
        {
            if (isEditMode)
            {
                await ApiClient.UpdateStudentAsync(currentStudent);
                Snackbar.Add("Дані студента оновлено!", Severity.Success);
            }
            else
            {
                await ApiClient.AddStudentAsync(currentStudent);
                Snackbar.Add("Студента успішно додано!", Severity.Success);
            }
            CancelEdit();
            await LoadStudents();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Помилка збереження студента.", Severity.Error);
            Console.WriteLine(ex.Message);
        }
    }

    private void EditStudent(StudentModel s)
    {
        currentStudent = new() { Id = s.Id, FullName = s.FullName, GroupId = s.GroupId };
        isEditMode = true;
    }

    private void CancelEdit()
    {
        currentStudent = new();
        isEditMode = false;
    }

    private async Task DeleteStudent(int id)
    {
        try
        {
            await ApiClient.DeleteStudentAsync(id);
            Snackbar.Add("Студента видалено.", Severity.Info);
            await LoadStudents();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Помилка видалення студента.", Severity.Error);
            Console.WriteLine(ex.Message);
        }
    }
}
