@page "/manager/disciplines"
@inject ApiClient ApiClient
@inject ISnackbar Snackbar

<MudText Typo="Typo.h4" Class="mb-4">Керування дисциплінами</MudText>

<MudCard Elevation="3" Class="mb-4">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">@(isEditMode ? "Редагувати дисципліну" : "Додати дисципліну")</MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        <MudGrid>
            <MudItem xs="12" md="5">
                <MudTextField @bind-Value="currentDiscipline.Name" Label="Назва дисципліни" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>

            <MudItem xs="12" md="4">
                <MudSelect T="int" @bind-Value="currentDiscipline.TeacherId" Label="Оберіть викладача" Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem T="int" Value="0">-- Оберіть викладача --</MudSelectItem>
                    @if (teachersList != null)
                    {
                        @foreach (var t in teachersList)
                        {
                            <MudSelectItem T="int" Value="@t.Id">@t.FullName</MudSelectItem>
                        }
                    }
                </MudSelect>
            </MudItem>

            <MudGrid Class="mb-4 ml-1">
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="SearchTerm"
                                  @bind-Value:after="LoadDisciplines"
                                  Immediate="true"
                                  Placeholder="Пошук..."
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" md="2">
                    <MudSelect @bind-Value="SortBy"
                               @bind-Value:after="LoadDisciplines"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense">
                        <MudSelectItem Value="@("")">А - Я</MudSelectItem>
                        <MudSelectItem Value="@("name_desc")">Я - А</MudSelectItem>
                    </MudSelect>
                </MudItem>
            </MudGrid>

            <MudItem xs="12" md="3" Class="d-flex align-center">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveDiscipline" Class="mr-2">Зберегти</MudButton>
                @if (isEditMode)
                {
                    <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="CancelEdit">Скасувати</MudButton>
                }
            </MudItem>
        </MudGrid>
    </MudCardContent>
</MudCard>

<MudTable Items="@disciplines" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@(disciplines == null)" LoadingProgressColor="Color.Info" Elevation="3">
    <HeaderContent>
        <MudTh>ID</MudTh>
        <MudTh>Назва</MudTh>
        <MudTh>Викладач</MudTh>
        <MudTh>Дії</MudTh>
    </HeaderContent>

    <RowTemplate>
        <MudTd DataLabel="ID">@context.Id</MudTd>
        <MudTd DataLabel="Назва">@context.Name</MudTd>
        <MudTd DataLabel="Викладач">
            @(teachersList?.FirstOrDefault(t => t.Id == context.TeacherId)?.FullName ?? $"ID: {context.TeacherId}")
        </MudTd>
        <MudTd DataLabel="Дії">
            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Warning" OnClick="() => EditDiscipline(context)" Class="mr-2">
                Змінити
            </MudButton>
            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Error" OnClick="() => DeleteDiscipline(context.Id)">
                Видалити
            </MudButton>
        </MudTd>
    </RowTemplate>
</MudTable>


@code {
    private List<DisciplineModel> disciplines;
    private List<TeacherModel> teachersList;
    private DisciplineModel currentDiscipline = new();
    private bool isEditMode = false;
    private string SearchTerm = "";
    private string SortBy = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadDisciplines();
        await LoadTeachers();
    }

    private async Task LoadDisciplines() => disciplines = await ApiClient.GetDisciplinesAsync(SearchTerm, SortBy);
    private async Task LoadTeachers() => teachersList = await ApiClient.GetTeachersAsync();

    private async Task SaveDiscipline()
    {
        if (currentDiscipline.TeacherId == 0 || string.IsNullOrWhiteSpace(currentDiscipline.Name))
        {
            return;
        }

        if (isEditMode) await ApiClient.UpdateDisciplineAsync(currentDiscipline);
        else await ApiClient.AddDisciplineAsync(currentDiscipline);
        CancelEdit();
        await LoadDisciplines();
    }

    private void EditDiscipline(DisciplineModel d) { currentDiscipline = new() { Id = d.Id, Name = d.Name, TeacherId = d.TeacherId }; isEditMode = true; }
    private void CancelEdit() { currentDiscipline = new(); isEditMode = false; }
    private async Task DeleteDiscipline(int id) { await ApiClient.DeleteDisciplineAsync(id); await LoadDisciplines(); }
}
