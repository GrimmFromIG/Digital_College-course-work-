@page "/manager/disciplines"
@inject ApiClient ApiClient

<h1>Керування дисциплінами</h1>

<div class="card p-3 mb-4">
    <h4>@(isEditMode ? "Редагувати дисципліну" : "Додати дисципліну")</h4>
    <div class="row g-3">
        <div class="col-md-5">
            <input type="text" class="form-control" @bind="currentDiscipline.Name" placeholder="Назва дисципліни" />
        </div>
        <div class="col-md-4">
            <select class="form-select" @bind="currentDiscipline.TeacherId">
                <option value="0">-- Оберіть викладача --</option>
                @if (teachersList != null)
                {
                    @foreach (var t in teachersList)
                    {
                        <option value="@t.Id">@t.FullName</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-3">
            <button class="btn btn-primary w-100" @onclick="SaveDiscipline">Зберегти</button>
            @if (isEditMode)
            {
                <button class="btn btn-link" @onclick="CancelEdit">Скасувати</button>
            }
        </div>
    </div>
</div>

<div class="row mb-3">
    <div class="col-md-8">
        <input type="text" class="form-control" @bind="SearchTerm" @bind:event="oninput" @bind:after="LoadDisciplines" placeholder="Пошук..." />
    </div>
    <div class="col-md-4">
        <select class="form-select" @bind="SortBy" @bind:after="LoadDisciplines">
            <option value="">А - Я</option>
            <option value="name_desc">Я - А</option>
        </select>
    </div>
</div>

<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Назва</th>
            <th>Викладач</th>
            <th>Дії</th>
        </tr>
    </thead>
    <tbody>
        @if (disciplines == null)
        {
            <tr><td colspan="4" class="text-center">Завантаження...</td></tr>
        }
        else
        {
            @foreach (var d in disciplines)
            {
                <tr>
                    <td>@d.Id</td>
                    <td>@d.Name</td>
                    <td>
                        @(teachersList?.FirstOrDefault(t => t.Id == d.TeacherId)?.FullName ?? $"ID: {d.TeacherId}")
                    </td>
                    <td>
                        <button class="btn btn-sm btn-warning" @onclick="() => EditDiscipline(d)">Змінити</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteDiscipline(d.Id)">Видалити</button>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

@code {
    private List<DisciplineModel> disciplines;
    private List<TeacherModel> teachersList;
    private DisciplineModel currentDiscipline = new();
    private bool isEditMode = false;
    private string SearchTerm = "";
    private string SortBy = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadDisciplines();
        await LoadTeachers();
    }

    private async Task LoadDisciplines() => disciplines = await ApiClient.GetDisciplinesAsync(SearchTerm, SortBy);
    private async Task LoadTeachers() => teachersList = await ApiClient.GetTeachersAsync();

    private async Task SaveDiscipline()
    {
        if (currentDiscipline.TeacherId == 0 || string.IsNullOrWhiteSpace(currentDiscipline.Name))
        {
            return; // Проста валідація на порожні поля
        }

        if (isEditMode) await ApiClient.UpdateDisciplineAsync(currentDiscipline);
        else await ApiClient.AddDisciplineAsync(currentDiscipline);
        CancelEdit();
        await LoadDisciplines();
    }

    private void EditDiscipline(DisciplineModel d) { currentDiscipline = new() { Id = d.Id, Name = d.Name, TeacherId = d.TeacherId }; isEditMode = true; }
    private void CancelEdit() { currentDiscipline = new(); isEditMode = false; }
    private async Task DeleteDiscipline(int id) { await ApiClient.DeleteDisciplineAsync(id); await LoadDisciplines(); }
}