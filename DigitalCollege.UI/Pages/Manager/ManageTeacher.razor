@page "/manager/teachers"
@inject ApiClient ApiClient
@inject AuthService AuthService
@inject ISnackbar Snackbar

<PageTitle>Керування викладачами</PageTitle>

@if (!AuthService.IsInRole("Manager"))
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Elevation="3" Class="my-4">
        <MudText Typo="Typo.h6">Доступ обмежено!</MudText>
        <MudText>Тільки користувачі з роллю <strong>Менеджер</strong> мають право редагувати дані викладачів.</MudText>
        <MudButton Variant="Variant.Outlined" Color="Color.Inherit" Link="login" Class="mt-2">
            Увійти з іншою роллю
        </MudButton>
    </MudAlert>
}
else
{
    <MudText Typo="Typo.h4" Class="mb-4">Керування викладачами (Режим Менеджера)</MudText>

    <MudCard Elevation="3" Class="mb-4">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">@(isEditMode ? "Редагування викладача" : "Створення нового викладача")</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudGrid AlignItems="AlignItems.Center">
                <MudItem xs="12" md="9">
                    <MudTextField @bind-Value="currentTeacher.FullName"
                                  Label="ПІБ викладача"
                                  Placeholder="Введіть ПІБ..."
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" md="3" Class="d-flex gap-2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveTeacher" Class="w-100">
                        Зберегти
                    </MudButton>
                    @if (isEditMode)
                    {
                        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="CancelEdit">
                            Скасувати
                        </MudButton>
                    }
                </MudItem>
            </MudGrid>
        </MudCardContent>
    </MudCard>

    <MudTable Items="@teachers" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@(teachers == null)" LoadingProgressColor="Color.Info" Elevation="3">
        <HeaderContent>
            <MudTh>ID</MudTh>
            <MudTh>ПІБ викладача</MudTh>
            <MudTh>Дії</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="ID">@context.Id</MudTd>
            <MudTd DataLabel="ПІБ викладача">@context.FullName</MudTd>
            <MudTd DataLabel="Дії">
                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Warning" OnClick="() => Edit(context)" Class="mr-2">
                    Змінити
                </MudButton>
                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Error" OnClick="() => Delete(context.Id)">
                    Видалити
                </MudButton>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body1" Align="Align.Center" Class="py-4 text-muted">Жодного викладача ще не додано.</MudText>
        </NoRecordsContent>
    </MudTable>
}

@code {
    private List<TeacherModel> teachers;
    private TeacherModel currentTeacher = new();
    private bool isEditMode = false;

    protected override async Task OnInitializedAsync()
    {
        if (AuthService.IsInRole("Manager"))
        {
            await LoadTeachers();
        }
    }

    private async Task LoadTeachers()
    {
        try
        {
            teachers = await ApiClient.GetTeachersAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Помилка завантаження списку викладачів.", Severity.Error);
            Console.WriteLine(ex.Message);
        }
    }

    private async Task SaveTeacher()
    {
        if (string.IsNullOrWhiteSpace(currentTeacher.FullName))
        {
            Snackbar.Add("Будь ласка, введіть ПІБ викладача.", Severity.Warning);
            return;
        }

        try
        {
            if (isEditMode)
            {
                await ApiClient.UpdateTeacherAsync(currentTeacher);
                Snackbar.Add("Дані викладача оновлено!", Severity.Success);
            }
            else
            {
                await ApiClient.AddTeacherAsync(currentTeacher);
                Snackbar.Add("Нового викладача успішно додано!", Severity.Success);
            }

            CancelEdit();
            await LoadTeachers();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Помилка збереження.", Severity.Error);
            Console.WriteLine(ex.Message);
        }
    }

    private void Edit(TeacherModel t)
    {
        currentTeacher = new() { Id = t.Id, FullName = t.FullName };
        isEditMode = true;
    }

    private void CancelEdit()
    {
        currentTeacher = new();
        isEditMode = false;
    }

    private async Task Delete(int id)
    {
        try
        {
            await ApiClient.DeleteTeacherAsync(id);
            Snackbar.Add("Викладача видалено.", Severity.Info);
            await LoadTeachers();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Помилка видалення.", Severity.Error);
            Console.WriteLine(ex.Message);
        }
    }
}
