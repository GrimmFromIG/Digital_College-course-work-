@page "/manager/groups"
@inject ApiClient ApiClient
@inject AuthService AuthService
@inject ISnackbar Snackbar

<PageTitle>Керування групами</PageTitle>

@if (!AuthService.IsInRole("Manager"))
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Elevation="3" Class="my-4">
        <MudText Typo="Typo.h6">Доступ обмежено!</MudText>
        <MudText>Тільки користувачі з роллю <strong>Менеджер</strong> мають право керувати групами.</MudText>
        <MudButton Variant="Variant.Outlined" Color="Color.Inherit" Link="login" Class="mt-2">
            Увійти з іншою роллю
        </MudButton>
    </MudAlert>
}
else
{
    <MudText Typo="Typo.h4" Class="mb-4">Керування групами академії</MudText>

    <MudCard Elevation="3" Class="mb-4">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">@(isEditMode ? "Редагувати групу" : "Створити нову групу")</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <EditForm Model="currentGroup" OnValidSubmit="SaveGroup">
                <DataAnnotationsValidator />

                <MudGrid AlignItems="AlignItems.Center">
                    <MudItem xs="12" md="9">
                        <MudTextField @bind-Value="currentGroup.Name"
                                      Label="Назва групи (наприклад: КН-21)..."
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      For="@(() => currentGroup.Name)" />
                    </MudItem>
                    <MudItem xs="12" md="3" Class="d-flex gap-2">
                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Class="w-100">
                            Зберегти
                        </MudButton>
                        @if (isEditMode)
                        {
                            <MudButton ButtonType="ButtonType.Button" Variant="Variant.Filled" Color="Color.Secondary" OnClick="CancelEdit">
                                Скасувати
                            </MudButton>
                        }
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudCardContent>
    </MudCard>

    <MudTable Items="@groups" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@(groups == null)" LoadingProgressColor="Color.Info" Elevation="3">
        <HeaderContent>
            <MudTh Style="width: 15%">ID</MudTh>
            <MudTh>Назва групи</MudTh>
            <MudTh Style="width: 25%">Дії</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="ID">@context.Id</MudTd>
            <MudTd DataLabel="Назва групи"><strong>@context.Name</strong></MudTd>
            <MudTd DataLabel="Дії">
                <MudButton Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small" OnClick="() => Edit(context)" Class="me-2">
                    Змінити
                </MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small" OnClick="() => Delete(context.Id)">
                    Видалити
                </MudButton>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body1" Align="Align.Center" Class="py-4 text-muted">Жодної групи ще не створено.</MudText>
        </NoRecordsContent>
    </MudTable>
}

@code {
    private List<GroupModel> groups;
    private GroupModel currentGroup = new();
    private bool isEditMode = false;

    protected override async Task OnInitializedAsync()
    {
        if (AuthService.IsInRole("Manager"))
        {
            await LoadGroups();
        }
    }

    private async Task LoadGroups()
    {
        try
        {
            groups = await ApiClient.GetGroupsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Помилка завантаження: {ex.Message}", Severity.Error);
        }
    }

    private async Task SaveGroup()
    {
        try
        {
            if (isEditMode)
            {
                await ApiClient.UpdateGroupAsync(currentGroup);
                Snackbar.Add("Групу успішно оновлено!", Severity.Success);
            }
            else
            {
                await ApiClient.AddGroupAsync(currentGroup);
                Snackbar.Add("Нову групу успішно додано!", Severity.Success);
            }

            CancelEdit();
            await LoadGroups();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Помилка збереження: {ex.Message}", Severity.Error);
        }
    }

    private void Edit(GroupModel g)
    {
        currentGroup = new() { Id = g.Id, Name = g.Name };
        isEditMode = true;
    }

    private void CancelEdit()
    {
        currentGroup = new();
        isEditMode = false;
    }

    private async Task Delete(int id)
    {
        try
        {
            await ApiClient.DeleteGroupAsync(id);
            Snackbar.Add("Групу видалено.", Severity.Info);
            CancelEdit();
            await LoadGroups();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Помилка видалення: {ex.Message}", Severity.Error);
        }
    }
}
