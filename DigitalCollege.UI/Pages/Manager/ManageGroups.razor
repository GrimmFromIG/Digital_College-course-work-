@page "/manager/groups"
@inject ApiClient ApiClient
@inject AuthService AuthService
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>Керування групами</PageTitle>

@if (!AuthService.IsInRole("Manager"))
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="my-4">Доступ обмежено!</MudAlert>
}
else
{
    <MudText Typo="Typo.h4" Class="mb-4">Керування групами</MudText>

    <MudCard Elevation="3" Class="mb-4">
        <MudCardContent>
            <EditForm Model="currentGroup" OnValidSubmit="SaveGroup">
                <DataAnnotationsValidator />
                <MudGrid AlignItems="AlignItems.Center">
                    <MudItem xs="12" md="9">
                        <MudTextField @bind-Value="currentGroup.Name" Label="Назва групи (наприклад: Б-121-24-1-ПІ)..." Variant="Variant.Outlined" Margin="Margin.Dense" For="@(() => currentGroup.Name)" />
                    </MudItem>
                    <MudItem xs="12" md="3" Class="d-flex gap-2">
                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Class="w-100">Зберегти</MudButton>
                        @if (isEditMode)
                        {
                            <MudButton Variant="Variant.Text" OnClick="CancelEdit">Скасувати</MudButton>
                        }
                    </MudItem>
                </MudGrid>
            </EditForm>
        </MudCardContent>
    </MudCard>

    <div class="d-flex flex-wrap gap-3 mb-4 align-center">
        <MudTextField @bind-Value="SearchTerm" Placeholder="Пошук за назвою..." Variant="Variant.Outlined" Margin="Margin.Dense" Class="flex-grow-1" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ApplySearch" Class="px-6">Знайти</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="ClearSearch">Очистити</MudButton>
    </div>

    <MudTable Items="@groups" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@(groups == null)" Elevation="3">
        <HeaderContent><MudTh>Назва групи</MudTh><MudTh Style="width: 25%">Дії</MudTh></HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Назва групи"><strong>@context.Name</strong></MudTd>
            <MudTd DataLabel="Дії">
                <MudButton Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small" OnClick="() => Edit(context)" Class="me-2">Змінити</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small" OnClick="() => Delete(context.Id)">Видалити</MudButton>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<GroupModel> groups;
    private GroupModel currentGroup = new();
    private bool isEditMode = false;
    private string SearchTerm = "";

    protected override async Task OnInitializedAsync() { if (AuthService.IsInRole("Manager")) await LoadGroups(); }

    private async Task ApplySearch() => await LoadGroups();
    private async Task ClearSearch() { SearchTerm = ""; await LoadGroups(); }

    private async Task LoadGroups() { try { groups = await ApiClient.GetGroupsAsync(SearchTerm); } catch { } }

    private async Task SaveGroup()
    {
        if (isEditMode) await ApiClient.UpdateGroupAsync(currentGroup);
        else await ApiClient.AddGroupAsync(currentGroup);
        CancelEdit(); await LoadGroups();
    }
    private void Edit(GroupModel g) { currentGroup = new() { Id = g.Id, Name = g.Name }; isEditMode = true; }
    private void CancelEdit() { currentGroup = new(); isEditMode = false; }

    private async Task Delete(int id)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", "Ви впевнені, що хочете видалити цю групу?");
        if (confirmed)
        {
            try
            {
                await ApiClient.DeleteGroupAsync(id);
                Snackbar.Add("Групу видалено.", Severity.Info);
                await LoadGroups();
            }
            catch (Exception ex)
            {
                Snackbar.Add(ex.Message, Severity.Error);
            }
        }
    }
}
