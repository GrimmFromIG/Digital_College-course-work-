@page "/login"
@inject AuthService AuthService
@inject NavigationManager NavManager
@inject ISnackbar Snackbar

<PageTitle>Вхід у систему</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudCard Elevation="4" Class="rounded-lg">
        <MudCardHeader Class="mud-theme-primary rounded-t-lg py-4">
            <CardHeaderContent>
                <MudText Typo="Typo.h5" Class="font-weight-bold text-white align-center d-flex justify-center">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Class="mr-2" />
                    Авторизація
                </MudText>
            </CardHeaderContent>
        </MudCardHeader>

        <MudCardContent Class="pa-6">
            <EditForm Model="loginModel" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />

                <MudTextField @bind-Value="loginModel.Email" 
                              Label="Електронна пошта" 
                              Variant="Variant.Outlined" 
                              Margin="Margin.Dense"
                              Class="mb-4"
                              For="@(() => loginModel.Email)"
                              Adornment="Adornment.Start" 
                              AdornmentIcon="@Icons.Material.Filled.Email" />

                <MudTextField @bind-Value="loginModel.Password" 
                              Label="Пароль" 
                              Variant="Variant.Outlined" 
                              Margin="Margin.Dense"
                              Class="mb-6"
                              InputType="InputType.Password"
                              For="@(() => loginModel.Password)"
                              Adornment="Adornment.Start" 
                              AdornmentIcon="@Icons.Material.Filled.Key" />

                <MudButton ButtonType="ButtonType.Submit" 
                           Variant="Variant.Filled" 
                           Color="Color.Primary" 
                           Size="Size.Large" 
                           FullWidth="true" 
                           Class="mb-3 font-weight-bold">
                    Увійти в систему
                </MudButton>

                <MudButton Variant="Variant.Text" 
                           Color="Color.Default" 
                           FullWidth="true"
                           OnClick="LoginAsGuest">
                    Продовжити як Гість
                </MudButton>
            </EditForm>
        </MudCardContent>
    </MudCard>

    <MudAlert Severity="Severity.Info" Class="mt-6">
        <MudText Typo="Typo.subtitle2" Class="font-weight-bold">Тестові акаунти (Email / Пароль):</MudText>
        <ul style="margin-bottom: 0;">
            <li>Менеджер: <b>admin@college.ua</b> / <b>admin</b></li>
            <li>Викладач: <b>teacher@college.ua</b> / <b>teacher</b></li>
            <li>Студент: <b>student@college.ua</b> / <b>student</b></li>
        </ul>
    </MudAlert>
</MudContainer>

@code {
    private LoginRequest loginModel = new();

    private async Task HandleLogin()
    {
        bool isSuccess = await AuthService.LoginWithCredentialsAsync(loginModel.Email, loginModel.Password);

        if (isSuccess)
        {
            Snackbar.Add($"Вітаємо, {AuthService.CurrentUser.FullName}!", Severity.Success);
            NavManager.NavigateTo("/");
        }
        else
        {
            Snackbar.Add("Невірний email або пароль!", Severity.Error);
        }
    }

    private async Task LoginAsGuest()
    {
        await AuthService.LoginAsGuestAsync();
        NavManager.NavigateTo("/public");
    }

    public class LoginRequest
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Введіть Email")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Некоректний формат пошти")]
        public string Email { get; set; }

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Введіть пароль")]
        public string Password { get; set; }
    }
}
