@page "/public/disciplines"
@inject ApiClient ApiClient
@inject ISnackbar Snackbar

<PageTitle>Дисципліни кафедри</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Дисципліни кафедри</MudText>

<div class="d-flex flex-column flex-md-row gap-3 mb-4">
    <MudTextField @bind-Value="SearchTerm"
                  @bind-Value:after="LoadDisciplines"
                  Immediate="true"
                  Placeholder="Пошук дисципліни..."
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Class="flex-grow-1" />

    <MudSelect T="string" @bind-Value="SortBy"
               @bind-Value:after="LoadDisciplines"
               Variant="Variant.Outlined"
               Margin="Margin.Dense"
               Style="min-width: 200px;">
        <MudSelectItem Value="@("")">А - Я</MudSelectItem>
        <MudSelectItem Value="@("name_desc")">Я - А</MudSelectItem>
    </MudSelect>
</div>

<MudTable Items="@disciplines" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@(disciplines == null)" LoadingProgressColor="Color.Info" Elevation="3">
    <HeaderContent>
        <MudTh>Назва</MudTh>
        <MudTh>Викладач</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Назва">@context.Name</MudTd>
        <MudTd DataLabel="Викладач">
            @if (string.IsNullOrEmpty(context.TeacherName))
            {
                <MudText Color="Color.Error" Typo="Typo.body2">Не призначено</MudText>
            }
            else
            {
                @context.TeacherName
            }
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Typo="Typo.body1" Align="Align.Center" Class="py-4 text-muted">Дисциплін не знайдено.</MudText>
    </NoRecordsContent>
</MudTable>

@code {
    private List<DisciplineModel> disciplines;
    private string SearchTerm = "";
    private string SortBy = "";

    protected override async Task OnInitializedAsync() => await LoadDisciplines();

    private async Task LoadDisciplines()
    {
        try
        {
            disciplines = await ApiClient.GetDisciplinesAsync(SearchTerm, SortBy);
        }
        catch (Exception ex)
        {
            Snackbar.Add("Не вдалося завантажити список дисциплін.", Severity.Error);
            Console.WriteLine(ex.Message);
        }
    }
}
