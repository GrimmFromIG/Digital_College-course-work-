@page "/public/about-fknt"

<PageTitle>Про факультет ФКНТ</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8 mb-16">
    <MudText Typo="Typo.h3" Color="Color.Primary" Class="font-weight-bold mb-6" Align="Align.Center">
        Факультет Комп'ютерних Наук та Технологій
    </MudText>

    <MudText Typo="Typo.h6" Align="Align.Center" Class="text-muted mb-12">
        Ваш шлях до передових інновацій, розробки програмного забезпечення та створення технологій майбутнього.
    </MudText>

    <MudGrid>
        <MudItem xs="12" md="4">
            <MudCard Elevation="4" Class="h-100 rounded-xl pa-4 text-center">
                <MudCardContent>
                    <MudIcon Icon="@Icons.Material.Filled.Code" Color="Color.Primary" Style="font-size: 4rem;" Class="mb-4" />
                    <MudText Typo="Typo.h5" Class="font-weight-bold mb-2">Сучасна інженерія</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">
                        Ми фокусуємося на актуальних технологіях розробки, зокрема глибокому вивченні екосистеми .NET, мови C# та архітектури сучасних веб-додатків. Наші студенти будують надійні та масштабовані системи.
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudCard Elevation="4" Class="h-100 rounded-xl pa-4 text-center">
                <MudCardContent>
                    <MudIcon Icon="@Icons.Material.Filled.SportsEsports" Color="Color.Secondary" Style="font-size: 4rem;" Class="mb-4" />
                    <MudText Typo="Typo.h5" Class="font-weight-bold mb-2">Game Development</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">
                        Факультет підтримує студентські ініціативи у сфері ігрової розробки. Ви зможете вивчати графіку, фізику та логіку рушіїв, щоб створювати власні цифрові світи та інтерактивні проєкти.
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudCard Elevation="4" Class="h-100 rounded-xl pa-4 text-center">
                <MudCardContent>
                    <MudIcon Icon="@Icons.Material.Filled.Memory" Color="Color.Success" Style="font-size: 4rem;" Class="mb-4" />
                    <MudText Typo="Typo.h5" Class="font-weight-bold mb-2">Апаратне забезпечення</MudText>
                    <MudText Typo="Typo.body2" Class="text-secondary">
                        Розуміння того, як працює софт на рівні заліза — наша гордість. Вивчення комп'ютерної архітектури, асемблера (MARIE) та взаємодії програм з мікропроцесорами робить наших випускників універсальними спеціалістами.
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    <MudPaper Elevation="0" Class="mt-12 pa-8 rounded-xl mud-theme-primary">
        <MudGrid AlignItems="AlignItems.Center">
            <MudItem xs="12" md="8">
                <MudText Typo="Typo.h4" Class="font-weight-bold text-white mb-2">Готові приєднатися до нас?</MudText>
                <MudText Typo="Typo.body1" Class="text-white">
                    Відкрийте для себе світ IT разом з найкращими викладачами та сучасними лабораторіями.
                </MudText>
            </MudItem>
            <MudItem xs="12" md="4" Class="d-flex justify-end">
                <MudButton Variant="Variant.Filled" Color="Color.Surface" Size="Size.Large" Href="/public/disciplines" Class="font-weight-bold text-primary px-8">
                    Переглянути дисципліни
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>
</MudContainer>