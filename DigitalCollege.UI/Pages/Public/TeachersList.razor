@page "/public/teachers"
@inject ApiClient apiClient
@inject ISnackbar Snackbar

<PageTitle>Наші викладачі</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Наші викладачі</MudText>

<div class="d-flex flex-column flex-md-row gap-3 mb-4">
    <MudTextField @bind-Value="SearchTerm"
                  @bind-Value:after="LoadTeachers"
                  Immediate="true"
                  Placeholder="Пошук викладача..."
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Class="flex-grow-1" />

    <MudSelect T="string" @bind-Value="SortBy"
               @bind-Value:after="LoadTeachers"
               Variant="Variant.Outlined"
               Margin="Margin.Dense"
               Style="min-width: 200px;">
        <MudSelectItem Value="@("")">А - Я</MudSelectItem>
        <MudSelectItem Value="@("name_desc")">Я - А</MudSelectItem>
    </MudSelect>
</div>

@if (teachers == null)
{
    <div class="d-flex justify-center my-6">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    </div>
}
else if (!teachers.Any())
{
    <MudText Typo="Typo.body1" Align="Align.Center" Class="py-4 text-muted">Викладачів не знайдено.</MudText>
}
else
{
    <MudGrid>
        @foreach (var teacher in teachers)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="3" Class="h-100 rounded-lg">
                    <MudCardContent>
                        <div class="d-flex align-center mb-3">
                            <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Class="mr-3">
                                @(string.IsNullOrWhiteSpace(teacher.FullName) ? "?" : teacher.FullName.FirstOrDefault().ToString().ToUpper())
                            </MudAvatar>

                            <MudText Typo="Typo.h6" Class="font-weight-bold">@teacher.FullName</MudText>
                        </div>

                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Внутрішній ID: @teacher.Id
                        </MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private List<TeacherModel> teachers;
    private string SearchTerm = "";
    private string SortBy = "";

    protected override async Task OnInitializedAsync() => await LoadTeachers();

    private async Task LoadTeachers()
    {
        try
        {
            teachers = await apiClient.GetTeachersAsync(SearchTerm, SortBy);

        }
        catch (Exception ex)
        {
            Snackbar.Add("Не вдалося завантажити список викладачів.", Severity.Error);
            Console.WriteLine(ex.Message);
        }
    }
}
