@page "/teacher/grades"
@inject ApiClient ApiClient
@inject AuthService AuthService
@inject ISnackbar Snackbar

<PageTitle>Журнал оцінювання</PageTitle>

@if (!AuthService.IsInRole("Teacher"))
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Elevation="3" Class="my-4">
        <MudText Typo="Typo.h6">Доступ обмежено!</MudText>
        <MudText>Ця сторінка доступна виключно для користувачів із роллю <strong>Викладач</strong>.</MudText>
    </MudAlert>
}
else
{
    <MudText Typo="Typo.h4" Class="mb-4">Виставлення оцінок студентам</MudText>

    <MudGrid Class="mb-6">
        <MudItem xs="12" md="8">
            <EditForm Model="newGrade" OnValidSubmit="SubmitGrade">
                <DataAnnotationsValidator />

                <MudCard Elevation="3" Class="h-100 rounded-lg pa-2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6" Class="text-secondary font-weight-bold">Нова оцінка</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudGrid>
                            <MudItem xs="12" md="6">
                                <MudSelect T="int" @bind-Value="newGrade.StudentId" Label="Студент" Variant="Variant.Outlined" For="@(() => newGrade.StudentId)" Margin="Margin.Dense">
                                    <MudSelectItem T="int" Value="0">-- Оберіть студента --</MudSelectItem>
                                    @if (studentsList != null)
                                    {
                                        @foreach (var s in studentsList)
                                        {
                                            <MudSelectItem T="int" Value="@s.Id">@s.FullName (ID: @s.Id)</MudSelectItem>
                                        }
                                    }
                                </MudSelect>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <MudSelect T="int" @bind-Value="newGrade.DisciplineId" Label="Дисципліна" Variant="Variant.Outlined" For="@(() => newGrade.DisciplineId)" Margin="Margin.Dense">
                                    <MudSelectItem T="int" Value="0">-- Оберіть дисципліну --</MudSelectItem>
                                    @if (disciplinesList != null)
                                    {
                                        @foreach (var d in disciplinesList)
                                        {
                                            <MudSelectItem T="int" Value="@d.Id">@d.Name</MudSelectItem>
                                        }
                                    }
                                </MudSelect>
                            </MudItem>

                            <MudItem xs="12" md="8">
                                <MudNumericField T="int" @bind-Value="newGrade.Value" Label="Бали (0-100)" Variant="Variant.Outlined" For="@(() => newGrade.Value)" Margin="Margin.Dense" Min="0" Max="100" />
                            </MudItem>

                            <MudItem xs="12" md="4" Class="d-flex align-end">
                                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Success" Class="w-100" StartIcon="@Icons.Material.Filled.CheckCircle">
                                    Поставити
                                </MudButton>
                            </MudItem>
                        </MudGrid>
                    </MudCardContent>
                </MudCard>
            </EditForm>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudCard Elevation="3" Class="h-100 rounded-lg pa-2" Style="border-left: 4px solid var(--mud-palette-primary);">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Class="text-secondary font-weight-bold d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.BarChart" Class="mr-2" /> Середній бал
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @if (disciplinesList == null)
                    {
                        <MudText Typo="Typo.body2" Class="text-muted">Завантаження дисциплін...</MudText>
                    }
                    else if (selectedStudentId == 0)
                    {
                        <MudText Typo="Typo.body2" Class="text-muted">Оберіть студента нижче, щоб побачити його успішність.</MudText>
                    }
                    else
                    {
                        <MudList T="string" Dense="true" Class="py-0">
                            @foreach (var d in disciplinesList)
                            {
                                var avg = GetDisciplineAverageForSelectedStudent(d.Id);
                                <MudListItem T="string" Class="px-0">
                                    <div class="d-flex justify-space-between align-center">
                                        <MudText Typo="Typo.body2" Class="text-truncate font-weight-medium" Style="max-width: 170px;">@d.Name</MudText>
                                        <MudChip T="string" Size="Size.Small" Color="@GetGradeColor(avg)">
                                            @(avg > 0 ? avg.ToString("F1") : "—")
                                        </MudChip>
                                    </div>
                                </MudListItem>
                            }
                        </MudList>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    <MudDivider Class="my-6" />

    <div class="d-flex flex-column flex-md-row justify-space-between align-center mb-4 gap-4">
        <MudText Typo="Typo.h5" Class="m-0 font-weight-bold">Перегляд оцінок студента</MudText>

        <MudSelect T="int" Value="selectedStudentId" ValueChanged="OnStudentSelectedForView" Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width: 300px; max-width: 400px; background-color: white;">
            <MudSelectItem T="int" Value="0">-- Оберіть студента для перегляду --</MudSelectItem>
            @if (studentsList != null)
            {
                @foreach (var s in studentsList)
                {
                    <MudSelectItem T="int" Value="@s.Id">@s.FullName</MudSelectItem>
                }
            }
        </MudSelect>
    </div>

    <MudTable Items="@viewGrades" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="3" Class="rounded-lg bg-white">
        <HeaderContent>
            <MudTh>Дисципліна</MudTh>
            <MudTh Style="width: 20%; text-align: center;">Бал</MudTh>
            <MudTh Style="width: 30%">Дата виставлення</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Дисципліна"><strong>@context.DisciplineName</strong></MudTd>
            <MudTd DataLabel="Бал" Style="text-align: center;">
                <MudChip T="string" Color="@GetGradeColor(context.Value)" Size="Size.Medium" Variant="Variant.Filled">
                    @context.Value
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Дата виставлення">
                <MudText Typo="Typo.body2" Class="text-muted">@context.DateAssigned.ToString("dd.MM.yyyy HH:mm")</MudText>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            @if (selectedStudentId == 0)
            {
                <MudText Typo="Typo.body1" Align="Align.Center" Class="py-4 text-muted">Оберіть студента зі списку вище, щоб відобразити його оцінки.</MudText>
            }
            else
            {
                <MudText Typo="Typo.body1" Align="Align.Center" Class="py-4 text-muted">У цього студента ще немає жодної оцінки.</MudText>
            }
        </NoRecordsContent>
    </MudTable>

    @if (viewGrades != null && viewGrades.Any())
    {
        var gpa = CalculateGpa();
        <div class="d-flex justify-end mt-4">
            <MudCard Elevation="3" Class="pa-4 rounded-lg" Style="min-width: 300px; border-left: 4px solid var(--mud-palette-success);">
                <div class="d-flex justify-space-between align-center mb-2">
                    <div>
                        <MudText Typo="Typo.caption" Class="text-uppercase font-weight-bold text-muted">Загальний GPA</MudText>
                        <MudText Typo="Typo.h4" Class="font-weight-bold text-dark m-0">@gpa.ToString("F1")</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.School" Color="Color.Success" Style="font-size: 3rem;" />
                </div>
                <MudProgressLinear Color="@GetGradeColor(gpa)" Value="@gpa" Size="Size.Medium" Rounded="true" />
            </MudCard>
        </div>
    }
}

@code {
    private CreateGradeModel newGrade = new();
    private List<StudentModel> studentsList;
    private List<DisciplineModel> disciplinesList;
    private List<GradeModel> viewGrades;

    private int selectedStudentId = 0;

    protected override async Task OnInitializedAsync()
    {
        if (AuthService.IsInRole("Teacher"))
        {
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        try
        {
            studentsList = await ApiClient.GetStudentsAsync();
            disciplinesList = await ApiClient.GetDisciplinesAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Помилка завантаження даних: {ex.Message}", Severity.Error);
        }
    }

    private async Task SubmitGrade()
    {
        try
        {
            newGrade.TeacherId = AuthService.CurrentUser?.Id ?? 0;
            await ApiClient.AssignGradeAsync(newGrade);

            Snackbar.Add("Оцінку успішно виставлено!", Severity.Success);

            int currentViewId = selectedStudentId;

            if (currentViewId == 0 && newGrade.StudentId > 0)
            {
                currentViewId = newGrade.StudentId;
                selectedStudentId = currentViewId;
            }

            newGrade = new CreateGradeModel();

            if (currentViewId != 0)
            {
                await RefreshGradesTable(currentViewId);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Помилка під час збереження: {ex.Message}", Severity.Error);
        }
    }

    private async Task OnStudentSelectedForView(int id)
    {
        selectedStudentId = id;
        await RefreshGradesTable(id);
    }

    private async Task RefreshGradesTable(int studentId)
    {
        if (studentId == 0)
        {
            viewGrades = null;
            return;
        }
        try
        {
            viewGrades = await ApiClient.GetStudentGradesAsync(studentId);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Помилка отримання даних журналу: {ex.Message}", Severity.Error);
        }
    }

    private double CalculateGpa()
    {
        if (viewGrades == null || !viewGrades.Any()) return 0;
        return viewGrades.Average(g => g.Value);
    }

    private double GetDisciplineAverageForSelectedStudent(int disciplineId)
    {
        if (viewGrades == null || !viewGrades.Any(g => g.DisciplineId == disciplineId))
            return 0;

        return viewGrades.Where(g => g.DisciplineId == disciplineId).Average(g => g.Value);
    }

    private Color GetGradeColor(double value)
    {
        if (value == 0) return Color.Default;
        if (value >= 74) return Color.Success;
        if (value >= 60) return Color.Warning;
        return Color.Error;
    }
}
